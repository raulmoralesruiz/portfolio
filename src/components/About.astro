---
import { Image } from "astro:assets";
import raul from "../assets/img/raul.png";
import { aboutData } from "../data/cv";
---

<section id="sobre-mi" class="py-20 container mx-auto px-4 max-w-4xl">
 <h2 class="text-3xl font-bold text-white mb-8 flex items-center">
  <span class="text-emerald-400 mr-2 font-mono text-2xl">01.</span> Sobre Mí
 </h2>
 <div class="grid grid-cols-1 md:grid-cols-3 gap-10 md:items-center">
  <div class="md:col-span-2 text-gray-300 text-lg leading-relaxed space-y-4">
   {aboutData.map((paragraph) => (
    <p set:html={paragraph} />
   ))}
  </div>

  <div tabindex="0" class="relative group w-72 h-72 mx-auto focus:outline-none">
   <div
    class="absolute inset-0 rounded-full border-2 border-emerald-400
           scale-110 group-hover:scale-100 group-focus:scale-100
           transition-transform duration-300 ease-out">
   </div>

   <div
    class="relative z-10 w-full h-full bg-neutral-900 rounded-full
           flex items-center justify-center
           border-2 border-emerald-400/30
           group-hover:border-emerald-400
           group-focus:border-emerald-400
           transition-colors duration-300">
    <Image
     src={raul}
     alt="Raúl Morales"
     loading="lazy"
     class="w-full h-full object-cover rounded-full"
    />
   </div>
  </div>
 </div>
</section>
