---
import { headerData } from "../data/cv";
---
<section class="h-screen flex flex-col justify-center items-start container mx-auto px-4 max-w-4xl pt-16">
    <span class="text-emerald-400 font-mono tracking-wider mb-4">HOLA, MI NOMBRE ES</span>
    <h1 class="text-5xl md:text-7xl font-bold text-white mb-4">
        {headerData.name}
    </h1>
    <h2 class="text-4xl md:text-6xl font-bold text-gray-400 mb-6">
        {headerData.role}
    </h2>
    <p class="text-xl text-gray-400 max-w-xl leading-relaxed mb-10" set:html={headerData.description.replace('Full-Stack', '<span class="text-emerald-400">Full-Stack</span>')} />
    <div class="flex flex-wrap gap-4">
        <a href="#proyectos" class="inline-block border border-emerald-400 text-emerald-400 px-8 py-4 rounded font-mono hover:bg-emerald-400/10 transition-colors">
            Ver mis proyectos
        </a>
        <button id="download-cv" class="inline-flex items-center gap-2 border border-white text-white px-8 py-4 rounded font-mono hover:bg-white/10 transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
            </svg>
            <span>Descargar CV</span>
        </button>
    </div>
</section>

<script>
    import { generateWordDocument } from "../utils/wordExport";

    const downloadBtn = document.getElementById('download-cv') as HTMLButtonElement | null;
    const spanText = downloadBtn?.querySelector('span');

    if (downloadBtn && spanText) {
        downloadBtn.addEventListener('click', async () => {
            const originalText = spanText.innerText;
            try {
                spanText.innerText = 'Generando...';
                downloadBtn.classList.add('opacity-70', 'cursor-not-allowed');
                downloadBtn.disabled = true;

                const blob = await generateWordDocument();

                const url = URL.createObjectURL(blob);
                const a = document.createElement('a');
                a.href = url;
                a.download = 'Raul-Morales-CV.docx';
                document.body.appendChild(a);
                a.click();
                document.body.removeChild(a);
                URL.revokeObjectURL(url);
            } catch (error) {
                console.error('Error generando CV:', error);
                alert('Hubo un error al generar el CV. Por favor, inténtalo de nuevo.');
            } finally {
                spanText.innerText = originalText;
                downloadBtn.classList.remove('opacity-70', 'cursor-not-allowed');
                downloadBtn.disabled = false;
            }
        });
    }
</script>
